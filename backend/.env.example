# Copy this file to .env and paste your real keys after the = signs.
# .env is git-ignored, so your keys never get committed.

# ElevenLabs (the voice). Free key at https://elevenlabs.io  (Profile menu -> API key)
ELEVENLABS_API_KEY=

# Groq (the fast cloud brain). Free key at https://console.groq.com  (API Keys -> Create)
# Optional: if unset, Cue falls back to the local Ollama brain.
GROQ_API_KEY=

# Which frontend origins may call this backend from a browser (comma-separated).
# Optional: defaults to the local dev frontend. In production set this to your
# real frontend domain, e.g. https://cue.example.com  (never "*").
CUE_CORS_ORIGINS=http://localhost:3000
